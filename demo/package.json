{
  "name": "demo-instance",
  "private": true,
  "type": "module",
  "description": "Flower Craft demo — qdcms instance umbrella (frontend + backend).",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=demo-frontend",
    "dev:remote": "VITE_QDCMS_BACKEND_MODE=remote npm run dev --workspace=demo-frontend",
    "dev:server": "npm run dev --workspace=demo-backend-server",
    "dev:full": "concurrently --names server,spa --prefix-colors blue,magenta \"npm:dev:server\" \"npm:dev:remote\"",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
