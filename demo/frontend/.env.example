# qdcms demo — low-level config layer.
#
# Copy to `.env.local` (gitignored by Vite by default) and tweak. All
# variables MUST start with `VITE_` to be exposed to the client bundle.
# See `src/qdcms.config.ts` for how these are consumed.

# Backend mode:
#   browser — fake backend running in this tab (default for the demo)
#   remote  — real HTTP backend at VITE_QDCMS_API_URL
VITE_QDCMS_BACKEND_MODE=browser

# Base URL of the real backend when VITE_QDCMS_BACKEND_MODE=remote.
# Ignored when mode=browser.
VITE_QDCMS_API_URL=/api/qdcms
