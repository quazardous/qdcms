# demo-backend-server — low-level config layer.
#
# Copy to `.env.local` (gitignored) and tweak. Plain process.env —
# read by `server.config.ts`.

# Path to the qdcms repo (= the "core"). Plugin discovery walks
# `<QDCMS_CORE>/node_modules/`. Auto-detected by walking up from
# cwd; override only when the layout is exotic (Docker / bundle).
# QDCMS_CORE=/abs/path/to/qdcms

# Port the HTTP server listens on. The demo SPA's vite proxy
# forwards /api/qdcms/* here when VITE_QDCMS_BACKEND_MODE=remote.
PORT=5181

# Database — sqlite for the demo.
#   '../data/demo.sqlite' → shared file at demo/data/, persists across reboots
#   ':memory:'            → fresh DB on every boot, no persistence (fast iter)
QDCMS_DB=../data/demo.sqlite

# SQL dialect. Matches the migration runner's hashing.
QDCMS_DIALECT=sqlite

# Run plugin migrations at boot (recommended). Set false to
# discover-only — useful for diagnostic CLI runs.
QDCMS_INSTALL_ON_BOOT=true
