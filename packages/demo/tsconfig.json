{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM"],
    "types": ["vite/client"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "vue": ["./node_modules/vue"],
      "vue-router": ["./node_modules/vue-router"],
      "@vue/*": ["./node_modules/@vue/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
