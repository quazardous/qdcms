{
  "name": "@quazardous/qdcms-api-emulator",
  "version": "0.1.0",
  "description": "Browser-side fetch interceptor that routes /api/qdcms/* URLs to a local backend.handle() — for static-site demos and tests of qdcms-frontend without a real server",
  "author": "quazardous",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@quazardous/qdcms-backend": "^0.1.0"
  },
  "devDependencies": {
    "@quazardous/qdcms-core": "^0.2.0",
    "@quazardous/qdcms-frontend": "^0.1.0",
    "@quazardous/qdcms-plugin-core": "^0.1.0",
    "@quazardous/qdcore": "*",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "qdcms",
    "qdcms-emulator",
    "fetch",
    "msw-alternative",
    "static-demo"
  ]
}
