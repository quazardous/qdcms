{
  "name": "qdcms",
  "version": "0.2.0",
  "description": "Block-centric public framework for Vue 3 SPAs, paired with qdadm",
  "author": "David Berlioz <berliozdavid@gmail.com> (https://github.com/quazardous)",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./layouts": "./src/layouts/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./tsconfig.preset.json": "./tsconfig.preset.json"
  },
  "files": [
    "src",
    "!src/**/__tests__",
    "!src/**/*.test.ts",
    "tsconfig.preset.json",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "vue",
    "vue3",
    "cms",
    "spa",
    "block-centric",
    "qdadm",
    "qdcms"
  ],
  "homepage": "https://github.com/quazardous/qdcms#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quazardous/qdcms.git",
    "directory": "packages/qdcms"
  },
  "bugs": {
    "url": "https://github.com/quazardous/qdcms/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@quazardous/qdcore": "file:../../../../qdadm/packages/qdcore"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  }
}
