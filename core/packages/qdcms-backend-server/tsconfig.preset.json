// status: framework preset — instances extend this, no edit
//
// Defaults for a Node-side qdcms instance running under tsx/tsc:
// strict TypeScript, ES2022, ESM, Node types in scope. Instances
// import via `{ "extends": "@quazardous/qdcms-backend-server/tsconfig.preset.json" }`
// — no need to copy the options into every instance.
{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  }
}
